#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: klogmsg [kubectl-logs-args...]

Read `kubectl logs` output and extract any JSON `message` fields onto a
single line. Pass arguments directly to `kubectl logs`. Add `-f` if you
want to follow the log stream.

Examples:
  klogmsg -n default my-pod
  klogmsg -f deployment/my-app --all-containers=true

Options:
  -h, --help  Show this help text.
EOF
}

if [[ $# -eq 0 ]]; then
  usage >&2
  exit 1
fi

case "${1-}" in
  -h|--help)
    usage
    exit 0
    ;;
esac

kubectl logs "$@" | jq -Rr 'fromjson? | [.. | .message? // empty] | map(select(length > 0)) | join(" | ")'
